      "Install": [
        { "Uri": "https://api.papermc.io/v2/projects/paper/versions/{{Version}}/builds/latest/downloads/paper-{{Version}}-latest.jar", "Path": "server.jar" },
        { "Uri": "https://raw.githubusercontent.com/hydren-dev/images_v2/main/spigotmc/server.properties", "Path": "server.properties" }
      ]
    },
    "Variables": { "Version": { "type": "text", "default": "1.21.1", "required": true } },
    "Meta": { "Version": "OGUltra Images v1" }
  },
