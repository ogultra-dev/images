    "AuthorName": "OGUltra",
    "Image": "ghcr.io/hydren-dev/yolks:java",
    "Cmd": "",
    "Env": ["START=java -Xms128M -XX:MaxRAMPercentage=95.0 -Dterminal.jline=false -Dterminal.ansi=true @user_jvm_args.txt @libraries/net/minecraftforge/forge/{{Version}}/unix_args.txt nogui"],
