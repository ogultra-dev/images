[
  {
    "Name": "Minecraft Java: Vanilla",
    "Description": "Official Minecraft Java Edition server from Mojang. Pure vanilla experience with no modifications.",
    "Author": "ogultra",
    "AuthorName": "OGUltra",
    "Image": "ghcr.io/hydren-dev/yolks:java",
    "Cmd": "",
    "Env": ["START=java -Xms128M -XX:MaxRAMPercentage=95.0 -Dterminal.jline=false -Dterminal.ansi=true -jar server.jar --nogui"],
    "Scripts": {
      "Install": [
        { "Uri": "https://api.papermc.io/v2/projects/paper/versions/1.21.1/builds/latest/downloads/paper-1.21.1-latest.jar", "Path": "server.jar" }
      ]
    },
    "Variables": { "Version": { "type": "text", "default": "1.21.1", "required": true } },
    "Meta": { "Version": "OGUltra Images v1" }
  },
  {
    "Name": "Minecraft Java: PaperMC",
