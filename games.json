[
  {
    "Name": "Game: CS2 (Counter-Strike 2)",
    "Description": "Counter-Strike 2 dedicated server via SteamCMD. Competitive FPS. Requires valid Steam credentials.",
    "Author": "ogultra",
    "AuthorName": "OGUltra",
    "Image": "ghcr.io/hydren-dev/yolks:steamcmd",
    "Cmd": "",
    "Env": ["START=./steamcmd.sh +login anonymous +force_install_dir ./cs2 +app_update 730 validate +quit && ./cs2/game/bin/linuxsteamrt64/cs2 -dedicated -console -usercon -port {{Port}} +map de_dust2"],
    "Scripts": { "Install": [] },
    "Variables": {
      "Port": { "type": "number", "default": "27015", "required": true },
      "MaxPlayers": { "type": "number", "default": "16", "required": false },
      "Map": { "type": "text", "default": "de_dust2", "required": false }
    },
    "Meta": { "Version": "OGUltra Images v1" }
  },
