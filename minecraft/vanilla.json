{
  "Image": "ghcr.io/skyport-team/images/java:21",
  "AltImages": [
    "ghcr.io/skyport-team/images/java:21",
    "ghcr.io/skyport-team/images/java:17",
    "ghcr.io/skyport-team/images/java:16",
    "ghcr.io/skyport-team/images/java:11",
    "ghcr.io/skyport-team/images/java:8"
  ],
  "Cmd": "",
  "Env": [
    "START=java -Xms128M -XX:MaxRAMPercentage=95.0 -Dterminal.jline=false -Dterminal.ansi=true -jar server.jar nogui"
  ],
  "StopCommand": "stop",
  "features": [
    "eula"
  ],
  "Scripts": {
    "Install": [
      {
        "Uri": "https://piston-data.mojang.com/v1/objects/{{ServerJarHash}}/server.jar",
        "Path": "server.jar"
      }
    ]
  },
  "Variables": {
    "ServerJarHash": {
      "type": "text",
      "default": "4707d00eb834b446575d89a61a11b5d548d8c001",
      "description": "Mojang server.jar SHA1 hash. Get from version_manifest.json",
      "required": true
    }
  },
  "Name": "Minecraft Java: Vanilla",
  "Description": "The official unmodified Minecraft Java Edition server by Mojang. No plugin or mod support, but supports all official versions.",
  "Author": "admin@ogultra.net",
  "AuthorName": "OgUltra Team",
  "Meta": {
    "Version": "OgUltra Images (v1)"
  }
}